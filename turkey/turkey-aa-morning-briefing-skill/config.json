      "world_rss_url": "https://www.aa.com.tr/en/rss/default?cat=world",
      "force_url": ""
    }
  },
  "translate": {
    "enabled": true,
    "temperature": 0.3,
    "max_tokens": 12000
  },
  "llm": {
    "provider": "minimax",
    "model": "MiniMax-M3",
    "api_key_env": "MINIMAX_API_KEY",
    "base_url": "https://api.minimaxi.com/v1",
    "temperature": 0.3,
    "max_tokens": 12000
  },
  "holidays": []
