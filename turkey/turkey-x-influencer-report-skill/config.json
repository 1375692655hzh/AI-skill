{
  "workdir": ".",
  "output_dir": "output",
  "cache_dir": ".cache/turkey-x-influencer-report",
  "target_date": "auto",
  "accounts_path": "accounts.yaml",
  "template_path": "templates/curated_template.txt",
  "fetch": {
    "provider": "xai",
    "window": "yesterday_start_to_now",
    "timezone": "Europe/Istanbul",
    "xai_model": "x-ai/grok-build-0.1",
    "xai_base_url": "https://openrouter.ai/api/v1",
    "xai_api_mode": "responses",
    "api_key_env": "XAI_API_KEY",
    "per_account_limit": 50,
    "max_pages_per_account": 5,
    "page_full_threshold": 8,
    "account_delay_seconds": 1.0,
    "timeout_seconds": 120,
    "max_consecutive_failures": 8,
    "cooldown_seconds": 30,
    "retries": 2,
    "retry_delay_seconds": 5,
    "enable_image_understanding": true,
    "min_priority": "low",
    "tiers": []
  },
  "translate": {
    "enabled": true,
    "temperature": 0.2,
    "max_tokens": 2048
  },
  "curated": {
    "enabled": true,
    "excerpt_chars_per_post": 600,
    "max_posts_in_prompt": 80,
    "temperature": 0.3,
    "max_tokens": 8000
  },
  "llm": {
    "provider": "minimax",
    "model": "MiniMax-M3",
    "api_key_env": "MINIMAX_API_KEY",
    "base_url": "https://api.minimaxi.com/v1",
    "temperature": 0.3,
    "max_tokens": 8000
  },
  "holidays": []
}
