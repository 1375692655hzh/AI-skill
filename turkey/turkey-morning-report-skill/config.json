{
  "workdir": ".",
  "output_dir": "output",
  "cache_dir": ".cache/turkey-morning-report",
  "target_date": "auto",
  "template_path": "templates/morning_briefing_template.txt",
  "sources": {
    "bloomberght_closing": {
      "enabled": true,
      "use_project_fetcher": false,
      "rss_url": "https://www.bloomberght.com/rss",
      "list_page_url": "https://www.bloomberght.com/tum-piyasa-haberleri",
      "title_patterns": [
        "Piyasalarda günün özeti",
        "Piyasa özeti"
      ],
      "fallback_search": true
    },
    "news": {
      "mode": "agent",
      "bloomberght": {
        "enabled": true,
        "include_closing_review": true,
        "include_breaking_news": true,
        "include_featured_news": true
      },
      "web_search": {
        "enabled": true,
        "queries": [
          "Turkey BIST stock market {target_date}",
          "USD TRY exchange rate {target_date}",
          "Turkey economic news {target_date}",
          "Borsa Istanbul latest news {target_date}",
          "US Iran sanctions oil {target_date} Turkey impact",
          "S&P 500 European markets {target_date}"
        ]
      },
      "x_search": {
        "enabled": false,
        "queries": [
          "Borsa Istanbul today",
          "Turkey stock market today",
          "USD TRY today"
        ]
      },
      "api": {
        "provider": "minimax",
        "model": "MiniMax-M3",
        "api_key": "${MINIMAX_API_KEY}",
        "base_url": "https://api.minimaxi.com/v1",
        "temperature": 0.3
      }
    }
  },
  "llm": {
    "provider": "minimax",
    "model": "MiniMax-M3",
    "api_key_env": "MINIMAX_API_KEY",
    "base_url": "https://api.minimaxi.com/v1",
    "temperature": 0.4,
    "max_tokens": 8000
  },
  "holidays": [],
  "brief": {
    "enabled": true,
    "template_path": "templates/morning_briefing_brief_template.txt",
    "min_chars": 200,
    "max_chars": 520,
    "max_tokens": 2000,
    "temperature": 0.3
  }
}
