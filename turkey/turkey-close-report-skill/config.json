{
  "workdir": ".",
  "output_dir": "output",
  "cache_dir": ".cache/turkey-close-report",
  "target_date": "auto",
  "template_path": "templates/close_report_template.txt",
  "sources": {
    "bloomberght_closing": {
      "enabled": true,
      "use_project_fetcher": false
    }
  },
  "llm": {
    "provider": "minimax",
    "model": "MiniMax-M3",
    "api_key_env": "MINIMAX_API_KEY",
    "base_url": "https://api.minimaxi.com/v1",
    "temperature": 0.4,
    "max_tokens": 8000
  },
  "holidays": [],
  "brief": {
    "enabled": true,
    "template_path": "templates/close_report_brief_template.txt",
    "min_chars": 400,
    "max_chars": 500,
    "max_tokens": 2000,
    "temperature": 0.3
  }
}
