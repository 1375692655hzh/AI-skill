{
  "workdir": ".",
  "output_dir": "output",
  "cache_dir": ".cache/turkey-close-report",
  "target_date": "auto",
  "template_path": "templates/close_report_template.txt",
  "sources": {
    "bloomberght_closing": {
      "enabled": true,
      "use_project_fetcher": false
    }
  },
  "llm": {
    "provider": "minimax",
    "model": "MiniMax-M3",
    "api_key_env": "MINIMAX_API_KEY",
    "base_url": "https://api.minimaxi.com/v1",
    "temperature": 0.4,
    "max_tokens": 8000
  },
  "holidays": [
    "2026-01-01",
    "2026-04-23",
    "2026-05-01",
    "2026-05-19",
    "2026-07-15",
    "2026-08-30",
    "2026-10-29",
    "2026-12-31"
  ]
}
